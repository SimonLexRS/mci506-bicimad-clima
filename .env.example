# Copia este archivo a .env y rellena los valores. NO commitees .env.

# Nombre del bucket de GCS donde se subirán los archivos crudos.
# Si queda vacío, scripts/extract.py omite la subida.
GCS_BUCKET_NAME=

# Ruta absoluta al JSON de credenciales de la service account de GCP.
# Ejemplo Windows: C:\Users\tu_usuario\.gcp\service-account.json
GOOGLE_APPLICATION_CREDENTIALS=
